# ═══════════════════════════════════════════════════════════════════════════════
# IP Care Technologies — Environment Variable Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the real values.
# .env.local is in .gitignore and will never be committed.
# This .example file IS committed — it documents what variables are needed.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Resend (email sending) ────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
# Leave blank in dev → emails are console-mocked, submissions still succeed
RESEND_API_KEY=

# ── Rental Quote email routing ────────────────────────────────────────────────
QUOTE_TO_EMAIL=info@ipcare.ae
# Must match a domain verified in Resend. Falls back to onboarding@resend.dev
# automatically when domain is not yet verified.
QUOTE_FROM_EMAIL=quotes@ipcare.ae

# ── reCAPTCHA v3 ─────────────────────────────────────────────────────────────
# Create a v3 site+secret pair at: https://www.google.com/recaptcha/admin
# Leaving blank bypasses reCAPTCHA server-side (safe for local dev only)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ── Contact & Careers forms ───────────────────────────────────────────────────
CONTACT_TO_EMAIL=info@ipcare.ae
CAREERS_TO_EMAIL=hr@ipcare.ae

# ── MongoDB (only for contact form + careers — NOT needed for rental quotes) ──
MONGO_URL=
DB_NAME=ipcare

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.ipcare.ae
